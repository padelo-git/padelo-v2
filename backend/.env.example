# Database
DATABASE_URL=postgresql+asyncpg://padelo:CHANGE_THIS_PASSWORD@localhost:5432/padelo_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT - GENERATE A SECURE KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_SECURE_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Firebase
FIREBASE_CREDENTIALS_PATH=path/to/firebase-credentials.json
FIREBASE_PROJECT_ID=your-project-id
